# Server Environment Variables
# Copy this file to .env and fill in real values before running.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Required: Your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS (Production) ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave unset in development to allow all origins.
# Example: https://your-app.vercel.app,https://www.yourdomain.com
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Safety Flags ─────────────────────────────────────────────────────────────
# Set to "true" in production to prevent silent fallback to in-memory mode.
# If MongoDB is unreachable, the server will refuse to start.
# DISABLE_MEMORY_FALLBACK=true

# ── Vercel Detection ─────────────────────────────────────────────────────────
# Automatically set by Vercel; do not set manually.
# VERCEL=1
